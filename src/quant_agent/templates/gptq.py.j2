"""GPTQ quantization for {{ model_id }}.

Generated by quant-agent. Requires: gptqmodel, transformers, datasets, torch (with CUDA).
    pip install gptqmodel transformers datasets accelerate
"""
from datasets import load_dataset
from gptqmodel import GPTQModel, QuantizeConfig
from transformers import AutoTokenizer

MODEL_ID = "{{ model_id }}"
OUTPUT_DIR = "{{ options.output_dir | default('./quantized-gptq') }}"
CALIB_DATASET = "{{ options.calib_dataset | default('allenai/c4') }}"
CALIB_SPLIT = "{{ options.calib_split | default('train') }}"
CALIB_N = {{ options.calib_samples | default(128) }}

quant_config = QuantizeConfig(
    bits={{ options.bits | default(4) }},
    group_size={{ options.group_size | default(128) }},
    desc_act={{ options.desc_act | default(True) }},
    sym={{ options.sym | default(True) }},
)


def load_calib(tokenizer, n: int) -> list[dict]:
    ds = load_dataset(CALIB_DATASET, "en", split=CALIB_SPLIT, streaming=True)
    samples = []
    for row in ds:
        text = row.get("text") or ""
        if len(text) < 512:
            continue
        enc = tokenizer(text, truncation=True, max_length=2048, return_tensors="pt")
        samples.append({"input_ids": enc["input_ids"][0], "attention_mask": enc["attention_mask"][0]})
        if len(samples) >= n:
            break
    return samples


def main() -> None:
    tokenizer = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)
    model = GPTQModel.load(MODEL_ID, quant_config, trust_remote_code=True)
    calib = load_calib(tokenizer, CALIB_N)
    model.quantize(calib)
    model.save(OUTPUT_DIR)
    tokenizer.save_pretrained(OUTPUT_DIR)
    print(f"Saved GPTQ-quantized model to {OUTPUT_DIR}")


if __name__ == "__main__":
    main()
