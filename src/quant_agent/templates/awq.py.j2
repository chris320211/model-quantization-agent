"""AWQ 4-bit quantization for {{ model_id }}.

Generated by quant-agent. Requires: autoawq, transformers, torch (with CUDA).
    pip install autoawq transformers accelerate
"""
from awq import AutoAWQForCausalLM
from transformers import AutoTokenizer

MODEL_ID = "{{ model_id }}"
OUTPUT_DIR = "{{ options.output_dir | default('./quantized-awq') }}"

quant_config = {
    "zero_point": {{ options.zero_point | default(True) }},
    "q_group_size": {{ options.group_size | default(128) }},
    "w_bit": {{ options.bits | default(4) }},
    "version": "{{ options.version | default('GEMM') }}",
}


def main() -> None:
    tokenizer = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)
    model = AutoAWQForCausalLM.from_pretrained(
        MODEL_ID, safetensors=True, device_map="auto", trust_remote_code=True
    )
    model.quantize(tokenizer, quant_config=quant_config)
    model.save_quantized(OUTPUT_DIR)
    tokenizer.save_pretrained(OUTPUT_DIR)
    print(f"Saved AWQ-quantized model to {OUTPUT_DIR}")


if __name__ == "__main__":
    main()
