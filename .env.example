# Anthropic Claude API key — required
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: raises GitHub API rate limit from 60 to 5000 req/hr (repo clones/README fetches)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: HuggingFace token for gated models (e.g. meta-llama/*)
# HUGGINGFACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Model override (optional)
QUANT_AGENT_MODEL=claude-sonnet-4-6
