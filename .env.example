# Anthropic Claude API key — required
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Voyage AI — embeddings (voyage-3-lite)
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx

# Qdrant Cloud — vector database
QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.us-east-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Cloudflare R2 — raw file storage (PDFs + repo zips)
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=your-bucket-name

# Optional: raises GitHub API rate limit from 60 to 5000 req/hr
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: HuggingFace token for gated models
# HUGGINGFACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Model override (optional)
QUANT_AGENT_MODEL=claude-sonnet-4-6
