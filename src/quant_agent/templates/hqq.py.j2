"""HQQ (Half-Quadratic Quantization) for {{ model_id }}.

Generated by quant-agent. Requires: hqq, transformers, torch (with CUDA).
    pip install hqq transformers accelerate

HQQ is calibration-free, so this runs quickly with no dataset dependency.
"""
from hqq.core.quantize import BaseQuantizeConfig
from hqq.models.hf.base import AutoHQQHFModel
from transformers import AutoTokenizer

MODEL_ID = "{{ model_id }}"
OUTPUT_DIR = "{{ options.output_dir | default('./quantized-hqq') }}"

quant_config = BaseQuantizeConfig(
    nbits={{ options.bits | default(4) }},
    group_size={{ options.group_size | default(64) }},
    quant_zero={{ options.quant_zero | default(False) }},
    quant_scale={{ options.quant_scale | default(False) }},
)


def main() -> None:
    tokenizer = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)
    model = AutoHQQHFModel.from_pretrained(MODEL_ID, trust_remote_code=True)
    AutoHQQHFModel.quantize_model(model, quant_config=quant_config)
    AutoHQQHFModel.save_quantized(model, OUTPUT_DIR)
    tokenizer.save_pretrained(OUTPUT_DIR)
    print(f"Saved HQQ-quantized model to {OUTPUT_DIR}")


if __name__ == "__main__":
    main()
