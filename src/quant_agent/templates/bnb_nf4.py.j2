"""bitsandbytes NF4 (QLoRA-style) quantization for {{ model_id }}.

Generated by quant-agent. Requires: bitsandbytes, transformers, accelerate, torch (with CUDA).
    pip install bitsandbytes transformers accelerate

Note: bnb NF4 is load-time quantization, not a separate pass. This script loads
the model in 4-bit and saves the quantized weights to disk.
"""
import torch
from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig

MODEL_ID = "{{ model_id }}"
OUTPUT_DIR = "{{ options.output_dir | default('./quantized-bnb-nf4') }}"

bnb_config = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_quant_type="{{ options.quant_type | default('nf4') }}",
    bnb_4bit_use_double_quant={{ options.double_quant | default(True) }},
    bnb_4bit_compute_dtype=torch.{{ options.compute_dtype | default('bfloat16') }},
)


def main() -> None:
    tokenizer = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)
    model = AutoModelForCausalLM.from_pretrained(
        MODEL_ID,
        quantization_config=bnb_config,
        device_map="auto",
        trust_remote_code=True,
    )
    model.save_pretrained(OUTPUT_DIR)
    tokenizer.save_pretrained(OUTPUT_DIR)
    print(f"Saved bnb-NF4 quantized model to {OUTPUT_DIR}")


if __name__ == "__main__":
    main()
